rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin or superadmin
    function isAdmin() {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return request.auth != null && 
             exists(userDocPath) && 
             (get(userDocPath).data.role == 'admin' || get(userDocPath).data.role == 'superadmin');
    }

    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // USERS Collection
    match /users/{userId} {
      // Owner Rules (Simple, no external function calls)
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
      
      // Admin Rules (Complex, involves function calls)
      allow read, update, delete: if request.auth != null && isAdmin();
    }

    // MESSAGES Collection (Contact Form)
    match /messages/{messageId} {
      // Anyone can create a message (Public Contact Form)
      // Only Admins can read messages
      allow create: if true; 
      allow read, update, delete: if isAdmin();
    }

    // INTERESTS Collection (Product Applications)
    match /interests/{interestId} {
      // Users can create interest
      // Users can read their own interests
      // Admins can read/write all
      allow create: if isAuth();
      allow read: if isAuth() && (resource.data.user.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isAuth() && resource.data.user.uid == request.auth.uid);
    }

    // COMPLIANCE DOCS Collection
    match /compliance_docs/{docId} {
      // Authenticated users can read docs
      // Only Admins can write (upload/delete)
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
